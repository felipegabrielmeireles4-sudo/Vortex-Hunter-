-- [ LÓGICA DE PROTEÇÃO PASSIVA ]
local escudado = false
BypassBtn.MouseButton1Click:Connect(function()
    escudado = not escudado
    BypassBtn.Text = escudado and "ESCUDO: ATIVO" or "ESCUDO VORTEX: OFF"
    BypassBtn.BackgroundColor3 = escudado and Color3.fromRGB(0, 180, 0) or Color3.fromRGB(180, 0, 0)
    
    local char = game.Players.LocalPlayer.Character
    if char and char:FindFirstChild("Humanoid") then
        char.Humanoid.BreakJointsOnDeath = not escudado
        char.Humanoid:SetStateEnabled(Enum.HumanoidStateType.Dead, not escudado)
    end
end)

game:GetService("RunService").Heartbeat:Connect(function()
    if escudado then
        local char = game.Players.LocalPlayer.Character
        local hum = char and char:FindFirstChild("Humanoid")
        if hum then
            if hum.Health <= 0 then hum.Health = 1 end -- Impede speed lock
            if hum.Health < 100 then hum.Health = 100 end
            if hum:GetState() == Enum.HumanoidStateType.Dead then
                hum:ChangeState(Enum.HumanoidStateType.GettingUp)
            end
        end
    end
end)

-- [ RADAR ELITE INDEPENDENTE ]
local suspeitos = {}
RadarBtn.MouseButton1Click:Connect(function()
    RadarBtn.Text = "BUSCANDO..."; RadarBtn.BackgroundColor3 = Color3.fromRGB(0, 100, 0)
    task.spawn(function()
        while task.wait(0.5) do
            for _, p in pairs(game.Players:GetPlayers()) do
                if p ~= game.Players.LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    if p.Character.HumanoidRootPart.Velocity.Magnitude > 165 and not suspeitos[p.Name] then
                        suspeitos[p.Name] = true
                        local l = Instance.new("TextLabel", ListFrame)
                        l.Size = UDim2.new(1, 0, 0, 25); l.Text = " [!] " .. p.Name
                        l.BackgroundColor3 = Color3.fromRGB(40, 0, 0); l.TextColor3 = Color3.new(1,1,1)
                    end
                end
            end
        end
    end)
end)

-- [ FUNÇÃO DE TAG ]
TagBtn.MouseButton1Click:Connect(function()
    local target = NameInput.Text
    for _, p in pairs(game.Players:GetPlayers()) do
        if string.find(p.Name:lower(), target:lower()) and p.Character then
            local h = p.Character:FindFirstChild("Head")
            if h then
                if h:FindFirstChild("VTag") then h.VTag:Destroy() end
                local b = Instance.new("BillboardGui", h); b.Name = "VTag"; b.Size = UDim2.new(0, 200, 0, 50); b.AlwaysOnTop = true
                local t = Instance.new("TextLabel", b); t.Size = UDim2.new(1, 0, 1, 0); t.Text = "ALVO VORTEX"
                t.TextColor3 = Color3.new(1,0,0); t.BackgroundTransparency = 1; t.TextScaled = true; t.Font = Enum.Font.SourceSansBold
            end
        end
    end
end)

ClearBtn.MouseButton1Click:Connect(function()
    for _, c in pairs(ListFrame:GetChildren()) do if c:IsA("TextLabel") then c:Destroy() end end
    suspeitos = {}
end)

FlyBtn.MouseButton1Click:Connect(function()
    loadstring(game:HttpGet("https://rawscripts.net/raw/Universal-Script-Invinicible-Flight-R15-45414"))()
end)
